# =====================================================
# SMSPro — Variables d'environnement (EXEMPLE)
# =====================================================
#
# ⚠️ IMPORTANT — SÉCURITÉ
#
# Ce fichier est VERSIONNÉ sur GitHub (visible par tous).
# N'inscrivez JAMAIS vos vrais credentials ici.
#
# Pour configurer Supabase et Twilio, vous avez 2 options :
#
# OPTION A (recommandée) : Via l'interface
#   1. Allez dans l'app → Paramètres → Connexion Supabase
#   2. Entrez vos identifiants Supabase (ils sont stockés dans
#      localStorage du navigateur, JAMAIS sur GitHub)
#   3. Idem pour Twilio dans Paramètres → SMS & Twilio
#
# OPTION B (pour Vercel/déploiement) :
#   1. Copiez ce fichier en .env.local
#   2. Remplacez les YOUR-PROJECT ci-dessous par vos vraies valeurs
#   3. Sur Vercel : Settings → Environment Variables
#
# =====================================================

# ===== Application =====
VITE_APP_NAME=SMSPro
VITE_APP_URL=http://localhost:5173

# ===== Supabase (Base de données + Auth) =====
# Trouvables sur : https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY-HERE

# ⚠️ UNIQUEMENT côté serveur (Edge Functions, scripts admin)
# ⚠️ NE JAMAIS préfixer par VITE_ (sinon exposé au navigateur)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY-HERE

# ===== Twilio (Envoi SMS) =====
# Trouvables sur : https://console.twilio.com/
TWILIO_ACCOUNT_SID=YOUR-ACCOUNT-SID-HERE
TWILIO_AUTH_TOKEN=YOUR-AUTH-TOKEN-HERE
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# URL du webhook (Optionnel, sinon calculé automatiquement)
TWILIO_WEBHOOK_SECRET=YOUR-WEBHOOK-SECRET

# ===== Sécurité (optionnel) =====
SESSION_SECRET=YOUR-SESSION-SECRET-HERE

# ===== Analytics (optionnel) =====
VITE_SENTRY_DSN=
VITE_GA_ID=

# =====================================================
# COPIEZ CE FICHIER EN .env.local ET REMPLACEZ LES VALEURS
# =====================================================
